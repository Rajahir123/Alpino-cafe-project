rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'denyteny123@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isKitchen() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'kitchen';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'planStatus']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['user', 'admin', 'kitchen'] &&
             data.planStatus in ['none', 'pending', 'active', 'expired'] &&
             (data.get('phone', null) == null || (data.phone is string && data.phone.size() <= 32)) &&
             (data.get('address', null) == null || (data.address is string && data.address.size() <= 1000));
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isKitchen();
      allow list: if request.auth.token.email == 'denyteny123@gmail.com' || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().role == 'user' || 
        (incoming().role == 'admin' && request.auth.token.email == 'denyteny123@gmail.com')
      );
      allow update: if (isOwner(userId) || isAdmin()) && (
        // Action: Update Profile (User)
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'address', 'proteinGoal', 'planId', 'planStatus', 'updatedAt', 'avgProtein', 'daysRemaining'])) ||
        // Action: Admin adjustments
        (isAdmin())
      );
    }

    // --- Menu Validation ---
    function isValidMenuItem(data) {
      return data.keys().hasAll(['name', 'category', 'protein']) &&
             data.name is string && data.name.size() <= 256 &&
             data.category in ['Bowl', 'Smoothie', 'Shake'] &&
             data.protein is number;
    }

    match /menu/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidMenuItem(incoming());
    }

    // --- Plans ---
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Orders ---
    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'status', 'date']) &&
             data.userId is string &&
             data.items is list && data.items.size() > 0 &&
             data.status in ['pending', 'preparing', 'out-for-delivery', 'delivered'];
    }

    match /orders/{orderId} {
      allow get: if isOwner(resource.data.userId) || isAdmin() || isKitchen();
      allow list: if isAdmin() || isKitchen() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isOwner(incoming().userId) && isValidOrder(incoming());
      allow update: if (isOwner(existing().userId) || isAdmin() || isKitchen()) && (
        (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['items', 'createdAt', 'id', 'userName', 'date', 'status', 'userId'])) ||
        (isKitchen() && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
    }

    // --- Payments ---
    function isValidPayment(data) {
      return data.keys().hasAll(['userId', 'amount', 'planId', 'status']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.status == 'pending';
    }

    match /payments/{paymentId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isEmailVerified() && isValidPayment(incoming());
      allow update: if isAdmin() && incoming().status in ['approved', 'rejected'];
    }

    // --- Assets ---
    match /assets/{assetId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Settings ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
